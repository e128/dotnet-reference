#!/usr/bin/env bash
# PreToolUse guard — blocks dangerous operations.

input=$(cat)

TOOL_NAME=$(echo "$input" | jq -r '.tool_name // ""' 2>/dev/null)
FILE_PATH=$(echo "$input" | jq -r '.tool_input.file_path // ""' 2>/dev/null)

# Block settings.json self-modification
if [[ "$TOOL_NAME" == "Write" || "$TOOL_NAME" == "Edit" ]]; then
    if echo "$FILE_PATH" | grep -q 'settings\.json'; then
        echo "BLOCK: Cannot modify .claude/settings.json without explicit user approval." >&2
        echo "Present the exact JSON to be added and wait for 'approved'." >&2
        exit 2
    fi
fi

exit 0
