{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:all"
  ],
  "timezone": "America/Chicago",
  "schedule": [
    "before 6am every weekday",
    "every weekend"
  ],
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 1,
  "branchConcurrentLimit": 1,
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["at any time"],
    "groupName": null,
    "labels": ["dependencies", "security"]
  },
  "packageRules": [
    {
      "description": "Security updates bypass schedule and grouping",
      "matchCategories": ["security"],
      "schedule": ["at any time"],
      "groupName": null,
      "automerge": true
    },
    {
      "description": "Major version bumps require manual review",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Patch and minor updates auto-merge",
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true
    }
  ]
}
