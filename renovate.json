{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "America/Chicago",
  "schedule": [
    "before 6am every weekday",
    "before 6am on saturday and sunday"
  ],
  "labels": [
    "dependencies"
  ],
  "minimumReleaseAge": "3 days",
  "prConcurrentLimit": 1,
  "branchConcurrentLimit": 1,
  "vulnerabilityAlerts": {
    "schedule": ["at any time"],
    "groupName": null,
    "labels": ["dependencies", "security"]
  },
  "packageRules": [
    {
      "description": "Security updates bypass schedule, grouping, and release age",
      "matchCategories": ["security"],
      "schedule": ["at any time"],
      "groupName": null,
      "minimumReleaseAge": "0 days",
      "automerge": true
    },
    {
      "description": "Major version bumps require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Patch and minor updates grouped and auto-merged",
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "non-major",
      "automerge": true
    }
  ]
}
