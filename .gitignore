# =============================================================================
# .gitignore for .NET/C# projects
# =============================================================================

# =============================================================================
# OS-specific
# =============================================================================
**/.DS_Store
Thumbs.db

# =============================================================================
# Secrets
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Build output
# =============================================================================
[Dd]ebug/
[Dd]ebugPublic/
[Dd]ebugPS/
[Rr]elease/
[Rr]eleases/
[Rr]eleasePS/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/
csx/
*.build.csdef

# =============================================================================
# Visual Studio
# =============================================================================
.vs/
Generated\ Files/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
*.sln.iml

# Visual Studio cache files
*.[Cc]ache
!?*.[Cc]ache/

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Trace Files
*.e2e

# Local History for Visual Studio
.localhistory/
.vshistory/

# =============================================================================
# VS Code
# =============================================================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# =============================================================================
# JetBrains Rider / IntelliJ
# =============================================================================
.idea/

# =============================================================================
# ReSharper
# =============================================================================
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# =============================================================================
# Compiled/intermediate files
# =============================================================================
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.tlog
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc
dlldata.c

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# =============================================================================
# .NET / NuGet
# =============================================================================
project.lock.json
project.fragment.lock.json
packages.lock.json
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Mono
mono_crash.*

# =============================================================================
# Test results and coverage
# =============================================================================
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml
BenchmarkDotNet.Artifacts/

# Code coverage
*.dotCover
.axoCover/*
!.axoCover/settings.json
coverage*.json
coverage*.xml
!coverage.config.xml
coverage*.info
*.coverage
*.coveragexml
OpenCover/

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# =============================================================================
# Database files
# =============================================================================
*.mdf
*.ldf
*.ndf
*.db
healthchecksdb

# =============================================================================
# Publishing
# =============================================================================
publish/
*.[Pp]ublish.xml
*.pubxml
*.publishproj

# =============================================================================
# Node.js
# =============================================================================
node_modules/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.pyc

# =============================================================================
# Other tools
# =============================================================================
.fake/
FodyWeavers.xsd
*.mm.*
AutoTest.Net/

# MSBuild logs
*.binlog

# =============================================================================
# Backup and upgrade files
# =============================================================================
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
~$*
*~

# =============================================================================
# Claude Code
# =============================================================================
.claude/settings.local.json
.claude/tmp/
.claude/worktrees/
.context/

# =============================================================================
# Project-specific
# =============================================================================

# Lode Coding session scraps
lode/tmp/
